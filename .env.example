# AI features (summaries + article Q&A) — any OpenAI-compatible endpoint works:
# OpenAI itself, vLLM, LiteLLM, Ollama (http://localhost:11434/v1), etc.
# Copy to .env and fill in. Without these, NewsRead runs fine as a plain reader.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
# Set to true when OPENAI_MODEL accepts image input: articles whose page has
# no extractable text (comics, charts) then get summarized from a rendered
# screenshot instead of failing.
OPENAI_MODEL_VISION=false

# Embedding model for semantic article search, served by the same endpoint.
# Optional: without it (or without the pgvector extension in Postgres),
# search falls back to keyword matching.
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Web search + page extraction for the Q&A agent. Optional: without either,
# the assistant answers from the article text only. Two providers:
#
# 1) Tavily — hosted search + extraction (https://tavily.com, free tier).
TAVILY_API_KEY=tvly-...
#
# 2) SearXNG — self-hosted metasearch, no API key; page extraction runs
#    locally. Takes precedence over Tavily when both are set.
#    Start one with: docker compose --profile search up -d searxng
#    (A backend running inside docker compose automatically uses
#    http://searxng:8080 instead; set NEWSREAD_SEARXNG_BASE_URL to force
#    an external instance.)
#SEARXNG_BASE_URL=http://localhost:8080

# --- Messaging integrations (share to Slack / Teams as the user) ---
# All optional: without them the platform just shows as unavailable in
# Settings -> Connections. Setup guide: docs/messaging-setup.md

# Slack app credentials (api.slack.com/apps -> Basic Information).
NEWSREAD_SLACK_CLIENT_ID=
NEWSREAD_SLACK_CLIENT_SECRET=
# Only needed for future inbound features (e.g. syncing Slack replies back
# as comments); harmless to set now.
NEWSREAD_SLACK_SIGNING_SECRET=

# Microsoft Entra app registration (portal.azure.com -> App registrations).
NEWSREAD_TEAMS_CLIENT_ID=
NEWSREAD_TEAMS_CLIENT_SECRET=
# "organizations" works for any work/school tenant; set a tenant id to pin
# the app to a single tenant (single-tenant registration).
NEWSREAD_TEAMS_TENANT=organizations

# Public base URL for OAuth callbacks. Slack requires HTTPS, so in local dev
# point this at a tunnel to the backend, e.g. ngrok:
#   ngrok http --domain=<your-static-domain> 8000
#NEWSREAD_OAUTH_REDIRECT_BASE=https://<your-static-domain>.ngrok-free.app
NEWSREAD_OAUTH_REDIRECT_BASE=http://localhost:8000

# Browser lands here after connecting (the settings page host).
NEWSREAD_FRONTEND_BASE_URL=http://localhost:3000

# Encrypts per-user Slack/Teams tokens at rest in Postgres. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
NEWSREAD_TOKEN_ENCRYPTION_KEY=
